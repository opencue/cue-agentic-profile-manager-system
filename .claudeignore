# Local agent/runtime artifacts that should not be loaded into Claude Code context by default.
.omx/logs/
.omx/state/
.omx/agent-worktrees/**/node_modules/
.omx/agent-worktrees/**/pnpm-lock.yaml
.omx/agent-worktrees/**/package-lock.json
.omc/logs/
.omc/state/
.omc/agent-worktrees/**/node_modules/
.omc/agent-worktrees/**/pnpm-lock.yaml
.omc/agent-worktrees/**/package-lock.json
.claude/worktrees/

# Dependency and generated output.
node_modules/
**/node_modules/
dist/
build/
coverage/
.turbo/
.pnpm-store/
.yarn/cache/

# Large local logs and captures.
*.log
*.jsonl
*.ndjson
