# Dependencies
node_modules/
bun.lock.bak

# Build artifact — node bundle, regenerated by `bun run build:bundle` / prepack
dist/

# Profile runtime / cache
profiles/_active
profiles/_cache/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Cloned marketplace (not part of this repo)
claude-plugins-official/

# Generated runtime (lives at ~/.config/cue/ but excluded if symlinked in for inspection)
.cue-hash

# OMX / OMC agent state (per-session traces + mission state, not source-controlled)
.omx/
.omc/
andrej-karpathy-skills/
agentshield/
awesome-clis/

# Locally-cloned third-party skills (have their own .git/ — keep out of cue's tree)
.claude/skills/hirelens-showcase/
.claude/skills/jdfit/
.claude/skills/job-hunter/

# Third-party repos cloned for study (have their own .git/ — keep out of cue's tree)
vendor/
.gstack/
vibecode-pro-max-kit/

# user-local skill clones (nested .git) — force-added as stray gitlinks with no
# .gitmodules URL, which broke CI submodule checkout on every job (PR #49/#51).
# jdfit + job-hunter also live canonically under resources/skills/skills/career/.
.agents/skills/hirelens-showcase/
.agents/skills/jdfit/
.agents/skills/job-hunter/
